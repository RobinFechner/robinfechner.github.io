---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Portfolio // Robin Fechner">
  <section class="py-20">

    <h1 class="text-5xl md:text-6xl font-bold">
      Robin Fechner
    </h1>

    <p class="mt-6 text-gray-400 max-w-2xl">
      Portfolio eines angehenden Fachinformatikers für Anwendungsentwicklung - mit Projekten rund um Java, Python, Datenbanken und Webentwicklung.
    </p>

    <div class="mt-10 flex gap-6">
      <a href="/profile"
         class="px-6 py-3 border border-[var(--color-raukhar-600)] rounded-xl hover:text-[var(--color-raukhar-400)] transition">
         Profil
      </a>

      <a href="/projects"
         class="px-6 py-3 rounded-xl bg-[var(--color-raukhar-600)] hover:bg-[var(--color-raukhar-700)] transition">
         Projekte
      </a>
    </div>

  </section>
</BaseLayout>