      <a class="text-raukhar-400 hover:underline" href="tel:+491773776880">
        +49 177 3776880
      </a>

      <div class="mt-6 flex flex-col gap-3">
        <a
          href="/Lebenslauf_Robin_Fechner.pdf?v=2026-03-31"
          class="inline-flex items-center justify-center w-full px-5 py-3 bg-raukhar-600 hover:bg-raukhar-700 transition rounded-xl"
